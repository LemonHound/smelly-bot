[
  {
    "name": "wikipedia",
    "type": "stdio",
    "command": "npx",
    "args": ["-y", "wikipedia-mcp@1.0.3"],
    "allowedTools": [
      "search",
      "readArticle"
    ]
  },
  {
    "name": "brave-search",
    "type": "stdio",
    "command": "npx",
    "args": ["-y", "@modelcontextprotocol/server-brave-search"],
    "allowedTools": [
      "brave_web_search"
    ]
  },
  {
    "name": "arxiv",
    "type": "stdio",
    "command": "npx",
    "args": ["-y", "arxiv-mcp-server"],
    "allowedTools": [
      "search_papers",
      "download_paper",
      "read_paper"
    ]
  },
  {
    "name": "github",
    "type": "http",
    "url": "https://api.githubcopilot.com/mcp/",
    "headers": { "Authorization": "Bearer $GITHUB_TOKEN" },
    "allowedTools": [
      "add_comment_to_pending_review",
      "add_issue_comment",
      "add_reply_to_pull_request_comment",
      "get_file_contents",
      "issue_read",
      "issue_write",
      "list_issues",
      "list_pull_requests",
      "pull_request_read",
      "search_issues",
      "search_pull_requests",
      "list_workflow_runs",
      "get_workflow_run",
      "list_workflow_run_artifacts",
      "list_workflow_jobs"
    ]
  }
]
