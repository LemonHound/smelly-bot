# Slack credentials
# From https://api.slack.com/apps -> your app
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Local dev only (Socket Mode) — omit in production
# When set, bot uses Socket Mode. When absent, bot uses HTTP webhooks + SLACK_SIGNING_SECRET.
SLACK_APP_TOKEN=xapp-your-app-level-token-with-connections-write

# Production only (HTTP webhooks) — omit locally when using Socket Mode
# SLACK_SIGNING_SECRET=your-signing-secret

# Connections
PORT=3000

# Logs
LOG_LEVEL=info

# Rate limits (global, enforced by rateLimit.js backed by Firestore)
RATE_LIMIT_PER_HOUR=200
RATE_LIMIT_PER_DAY=1000

# GCP / Firestore
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
FIRESTORE_DATABASE_ID=your-firestore-db-id
# Local dev only — points the Firestore SDK at the emulator. Leave unset in prod.
FIRESTORE_EMULATOR_HOST=localhost:8080

# Anthropic
ANTHROPIC_API_KEY=

# Thread context
THREAD_CONTEXT_MAX_CHARS=6000

# Reserved for future features (GitHub automation)
GITHUB_TOKEN=
GITHUB_REPO=owner/repo

# RAG / Vertex AI Search
# JSON key for the service account that has Drive read access and discoveryengine.editor role.
# In prod this is mounted from Secret Manager. Locally, paste the full JSON as a single line.
GOOGLE_DRIVE_SERVICE_ACCOUNT_KEY=
# ID of the Drive folder to index (the folder ID from its URL)
GOOGLE_DRIVE_FOLDER_ID=1S8bSxuAHHJOWwESVWM2vxF9eVHprkhG_
# GCS bucket used as staging area between Drive and Vertex AI Search
GCS_RAG_BUCKET=smelly-bot-bucket
# Data store ID from the Vertex AI Search console (created manually)
VERTEX_AI_DATASTORE_ID=smelly-bot-rag_1776719948464
# Engine/app ID from Vertex AI Search console
VERTEX_AI_ENGINE_ID=smelly-bot-rag_1776719767924
# Location of the Vertex AI Search data store (global, us, or eu)
VERTEX_AI_LOCATION=us
